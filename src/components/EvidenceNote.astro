---
import ClaimStatus from './ClaimStatus.astro';
import { claimStatus } from '../data/site';

type ClaimStatusKey = keyof typeof claimStatus;

interface Props {
  title?: string;
  text: string;
  status?: ClaimStatusKey;
  sourceLabel?: string;
  sourceHref?: string;
}

const { title, text, status, sourceLabel, sourceHref } = Astro.props;
---

<aside class="evidence-note">
  <div class="evidence-note__header">
    {status && <ClaimStatus status={status} />}
    {title && <strong>{title}</strong>}
  </div>
  <p>{text}</p>
  {
    sourceLabel && sourceHref && (
      <a class="evidence-note__source" href={sourceHref}>
        {sourceLabel}
      </a>
    )
  }
</aside>
