---
interface Props {
  keyName: string;
  label: string;
  title: string;
  description: string;
  cta: string;
}

const { keyName, label, title, description } = Astro.props;
---

<article class="contact-route" data-contact-route-card data-route={keyName} data-reveal>
  <button
    class="contact-route__button"
    type="button"
    data-contact-route={keyName}
    aria-pressed="false"
    aria-describedby={`contact-route-${keyName}-desc`}
  >
    <span class="contact-route__label">{label}</span>
    <span class="contact-route__title">{title}</span>
  </button>
  <p class="contact-route__description" id={`contact-route-${keyName}-desc`}>{description}</p>
</article>
