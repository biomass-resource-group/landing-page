---
interface ContextItem {
  label: string;
  value: string;
}

interface Props {
  paragraphs: readonly string[];
  context?: readonly ContextItem[];
  contextTitle?: string;
}

const { paragraphs, context = [], contextTitle = 'At a glance' } = Astro.props;
---

<div class="editorial" data-reveal>
  <div class="editorial__prose">
    {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
  </div>

  {
    context.length > 0 && (
      <aside class="editorial__panel" aria-label={contextTitle}>
        <p class="editorial__panel-label">{contextTitle}</p>
        <dl class="editorial__panel-facts">
          {context.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </aside>
    )
  }
</div>
