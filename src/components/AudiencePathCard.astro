---
interface Props {
  audience: string;
  title: string;
  description: string;
  href: string;
  cta: string;
}

const { audience, title, description, href, cta } = Astro.props;
---

<article class="audience-card" data-reveal>
  <span class="audience-card__label">{audience}</span>
  <h3>{title}</h3>
  <p>{description}</p>
  <a class="text-action" href={href}>
    {cta}
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M5 12h14M13 5l7 7-7 7"></path>
    </svg>
  </a>
</article>
