---
import ClaimStatus from './ClaimStatus.astro';
import { claimStatus } from '../data/site';

type ClaimStatusKey = keyof typeof claimStatus;

interface Props {
  value: string;
  label: string;
  note?: string;
  status?: ClaimStatusKey;
}

const { value, label, note, status } = Astro.props;
---

<article class="metric-card" data-reveal>
  <strong>{value}</strong>
  <h3>{label}</h3>
  {status && <ClaimStatus status={status} />}
  {note && <p>{note}</p>}
</article>
