---
import EvidenceNote from './EvidenceNote.astro';
import StatusBadge from './StatusBadge.astro';

interface Props {
  name: string;
  region: string;
  operatingEntity: string;
  status: string;
  statusLabel: string;
  feedstock: string;
  technology: string;
  carbonPathway: string;
  description: string;
  evidenceNote?: string;
}

const {
  name,
  region,
  operatingEntity,
  status,
  statusLabel,
  feedstock,
  technology,
  carbonPathway,
  description,
  evidenceNote,
} = Astro.props;
---

<article class="corridor-dossier" data-reveal>
  <header class="corridor-dossier__header">
    <div class="corridor-dossier__heading">
      <p class="corridor-dossier__region">{region}</p>
      <h3>{name}</h3>
    </div>
    <StatusBadge status={status} label={statusLabel} />
  </header>

  <p class="corridor-dossier__summary">{description}</p>

  <dl class="corridor-dossier__facts">
    <div><dt>Operating entity</dt><dd>{operatingEntity}</dd></div>
    <div><dt>Feedstock</dt><dd>{feedstock}</dd></div>
    <div><dt>Technology</dt><dd>{technology}</dd></div>
    <div><dt>Review pathway</dt><dd>{carbonPathway}</dd></div>
  </dl>

  {
    evidenceNote && (
      <EvidenceNote text={evidenceNote} status="underVerification" />
    )
  }
</article>
