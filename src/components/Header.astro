---
import { navLinks, siteMeta } from '../data/site';

const resolveHref = (href: string) =>
  href.startsWith('#') && Astro.url.pathname !== '/' ? `/${href}` : href;

const normalizePath = (value: string) => {
  if (value === '/') return '/';
  return value.endsWith('/') ? value : `${value}/`;
};

const currentPath = normalizePath(Astro.url.pathname);
const isActive = (href: string) => {
  if (href.startsWith('#')) return currentPath === '/';
  return currentPath === normalizePath(href);
};
---

<header class="site-header" data-site-header>
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label={`${siteMeta.name} home`}>
      <span class="brand__mark" aria-hidden="true">
        <img src="/favicon.svg" alt="" width="40" height="40" loading="eager" decoding="async" />
      </span>
      <span class="brand__wordmark">
        Biomass <span>Resource Group</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <ul class="site-nav__list">
        {
          navLinks.map((link) => (
            <li>
              <a
                class:list={[
                  'site-nav__link',
                  isActive(link.href) && 'site-nav__link--active',
                  'primary' in link && link.primary && 'site-nav__link--primary',
                ]}
                href={resolveHref(link.href)}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      class="site-menu-toggle"
      type="button"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation"
    >
      <span class="sr-only" data-menu-toggle-label>Open navigation</span>
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" data-menu hidden inert aria-hidden="true">
    <nav aria-label="Mobile navigation" data-mobile-nav>
      <ul class="mobile-menu__list">
        {
          navLinks.map((link) => (
            <li>
              <a
                class:list={['mobile-menu__link', isActive(link.href) && 'mobile-menu__link--active']}
                href={resolveHref(link.href)}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <noscript>
    <nav class="no-js-nav" aria-label="No-JavaScript navigation">
      <ul class="no-js-nav__list">
        {
          navLinks.map((link) => (
            <li>
              <a href={resolveHref(link.href)} aria-current={isActive(link.href) ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </noscript>
</header>
