---
interface System {
  title: string;
  status: string;
  statusLabel: string;
  role: string;
  fit: string;
  context: string;
}

interface Props {
  systems: readonly System[];
}

const { systems } = Astro.props;
---

<div class="tech-stack" data-reveal>
  <div class="tech-stack__head" aria-hidden="true">
    <span>System</span>
    <span>Role</span>
    <span>Operating fit</span>
    <span>Context</span>
    <span>Status</span>
  </div>

  <ul class="tech-stack__list">
    {
      systems.map((system) => (
        <li class="tech-stack__row">
          <span class="tech-stack__title">{system.title}</span>
          <span class="tech-stack__role">
            <span class="tech-stack__mobile-label" aria-hidden="true">Role</span>
            {system.role}
          </span>
          <span class="tech-stack__fit">
            <span class="tech-stack__mobile-label" aria-hidden="true">Operating fit</span>
            {system.fit}
          </span>
          <span class="tech-stack__context">
            <span class="tech-stack__mobile-label" aria-hidden="true">Context</span>
            {system.context}
          </span>
          <span class={`tech-stack__chip tech-stack__chip--${system.status}`}>{system.statusLabel}</span>
        </li>
      ))
    }
  </ul>
</div>
