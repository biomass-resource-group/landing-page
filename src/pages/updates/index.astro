---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageCta from '../../components/PageCta.astro';
import { formatFullDate } from '../../utils/formatDate';

const updates = (await getCollection('updates', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
  title="Updates"
  description="Field updates, project milestones, and company news from Biomass Resource Group."
  path="/updates/"
>
  <section class="page-hero">
    <div class="container page-hero__inner" data-reveal>
      <p class="page-hero__eyebrow">Updates</p>
      <h1>Operational milestones and company updates.</h1>
      <p>
        Publish-ready entries live as Markdown in the repository so new field notes and milestones can
        be added without rewriting templates.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="updates-list">
        {
          updates.map((update) => {
            const published = formatFullDate(update.data.publishedAt);
            const updateSlug = update.id.replace(/[^a-zA-Z0-9_-]/g, '-');
            const titleId = `update-${updateSlug}-title`;
            const metaId = `update-${updateSlug}-meta`;
            const summaryId = `update-${updateSlug}-summary`;

            return (
              <article class="updates-list__entry" data-reveal>
                <a
                  class="updates-list__item"
                  href={`/updates/${update.id}/`}
                  aria-labelledby={titleId}
                  aria-describedby={`${metaId} ${summaryId}`}
                >
                  <div class="updates-list__meta" id={metaId}>
                    <time datetime={update.data.publishedAt.toISOString()}>{published}</time>
                    <span>{update.data.category}</span>
                  </div>
                  <div class="updates-list__body">
                    <h2 id={titleId}>{update.data.title}</h2>
                    <p id={summaryId}>{update.data.summary}</p>
                  </div>
                  <span class="updates-list__action" aria-hidden="true">
                    Read update
                  </span>
                </a>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <PageCta
    label="Next Step"
    title="If an update opens a conversation, take it forward."
    intro="BRG keeps the updates archive public, but investor, buyer, and operator routes live on the dedicated contact page."
    primaryAction={{ label: 'Open contact page', href: '/contact/' }}
    secondaryAction={{ label: 'Review markets', href: '/markets/', variant: 'secondary' }}
  />
</BaseLayout>
