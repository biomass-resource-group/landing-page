---
import BaseLayout from '../layouts/BaseLayout.astro';
import AudiencePathCard from '../components/AudiencePathCard.astro';
import PageCta from '../components/PageCta.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import SectionIntro from '../components/SectionIntro.astro';
import StatusBadge from '../components/StatusBadge.astro';
import {
  audiencePaths,
  home,
  marketCorridors,
  pageMeta,
  siteMeta,
} from '../data/site';

const corridorAnchor = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const meta = pageMeta.home;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  path={meta.path}
  structuredData={structuredData}
  bodyClass="page--home"
>
  <section class="home-hero" data-hero>
    <div class="home-hero__backdrop" aria-hidden="true">
      <span class="home-hero__grain"></span>
    </div>
    <div class="container home-hero__inner">
      <div class="home-hero__copy" data-reveal>
        <p class="home-hero__eyebrow">{home.hero.label}</p>
        <h1 class="home-hero__title">{home.hero.title}</h1>
        <p class="home-hero__summary">{home.hero.summary}</p>
        <div class="hero__actions">
          <a class="button button--primary" href={home.hero.primaryAction.href}>{home.hero.primaryAction.label}</a>
          <a class="button button--secondary" href={home.hero.secondaryAction.href}>{home.hero.secondaryAction.label}</a>
        </div>
      </div>
      <div class="home-hero__schematic" aria-hidden="true" data-reveal>
        <figure class="schematic-map">
          <span class="schematic-map__corner schematic-map__corner--tl">N</span>
          <span class="schematic-map__corner schematic-map__corner--br">S</span>
          <span class="schematic-map__node schematic-map__node--feedstock">
            <span class="schematic-map__node-step">01</span>
            <span class="schematic-map__node-label">Feedstock</span>
          </span>
          <span class="schematic-map__node schematic-map__node--kiln">
            <span class="schematic-map__node-step">02</span>
            <span class="schematic-map__node-label">Kiln</span>
          </span>
          <span class="schematic-map__node schematic-map__node--buyer">
            <span class="schematic-map__node-step">03</span>
            <span class="schematic-map__node-label">Buyer</span>
          </span>
          <span class="schematic-map__node schematic-map__node--review">
            <span class="schematic-map__node-step">04</span>
            <span class="schematic-map__node-label">Review</span>
          </span>
          <span class="schematic-map__line schematic-map__line--a"></span>
          <span class="schematic-map__line schematic-map__line--b"></span>
          <span class="schematic-map__line schematic-map__line--c"></span>
          <figcaption class="schematic-map__caption">
            <span><span class="schematic-map__pip"></span>East Africa</span>
            <span><span class="schematic-map__pip"></span>Saudi Arabia</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section--proof" id="proof-strip">
    <div class="container">
      <div class="proof-strip" aria-label="BRG operating status">
        {
          home.proofStrip.map((item) => (
            <article class="proof-strip__item" data-reveal>
              <h2>{item.label}</h2>
              <p>{item.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="what-brg-does">
    <div class="container">
      <SectionIntro label={home.whatWeDo.label} title={home.whatWeDo.title} intro={home.whatWeDo.intro} />
      <ProcessFlow steps={home.whatWeDo.steps} />
    </div>
  </section>

  <section class="section section--tinted" id="audience-pathways">
    <div class="container">
      <SectionIntro label={home.audienceIntro.label} title={home.audienceIntro.title} intro={home.audienceIntro.intro} />
      <div class="card-grid card-grid--three">
        {
          audiencePaths.map((path) => (
            <AudiencePathCard
              audience={path.audience}
              title={path.title}
              description={path.description}
              href={path.href}
              cta={path.cta}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="active-corridors">
    <div class="container">
      <SectionIntro label={home.proof.label} title={home.proof.title} intro={home.proof.intro} />
      <div class="card-grid card-grid--two">
        {
          marketCorridors.map((corridor) => (
            <article class="info-card info-card--corridor" data-reveal>
              <div class="info-card__header">
                <div>
                  <span>{corridor.region}</span>
                  <h3>{corridor.name}</h3>
                </div>
                <StatusBadge status={corridor.status} label={corridor.statusLabel} />
              </div>
              <p>{corridor.description}</p>
              <dl class="definition-grid definition-grid--compact">
                <div><dt>Feedstock</dt><dd>{corridor.feedstock}</dd></div>
                <div><dt>Technology</dt><dd>{corridor.technology}</dd></div>
                <div><dt>Carbon pathway</dt><dd>{corridor.carbonPathway}</dd></div>
              </dl>
              <a class="text-action" href={`/markets/#${corridorAnchor(corridor.name)}`}>
                View {corridor.name}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7"></path>
                </svg>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <PageCta
    label={home.finalCta.label}
    title={home.finalCta.title}
    intro={home.finalCta.intro}
    primaryAction={home.finalCta.primaryAction}
    secondaryAction={home.finalCta.secondaryAction}
  />
</BaseLayout>
