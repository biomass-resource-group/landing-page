---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import UpdateCard from '../components/UpdateCard.astro';
import { formatFullDate, formatMonthYear } from '../utils/formatDate';
import {
  affiliations,
  commercialModel,
  contact,
  hero,
  impact,
  leadership,
  platform,
  regions,
  siteMeta,
  technology,
} from '../data/site';

const updates = (await getCollection('updates', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const latestUpdate = updates[0];
const latestUpdateMonthLabel = latestUpdate ? formatMonthYear(latestUpdate.data.publishedAt) : '';
const latestUpdateFullLabel = latestUpdate ? formatFullDate(latestUpdate.data.publishedAt) : '';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: siteMeta.title,
  url: siteMeta.siteUrl,
  description: siteMeta.description,
};
---

<BaseLayout
  title={siteMeta.title}
  description={siteMeta.description}
  structuredData={structuredData}
  bodyClass="page--home"
>
  <section class="home-hero" data-hero>
    <div class="home-hero__backdrop" aria-hidden="true">
      <span class="home-hero__terrain home-hero__terrain--north"></span>
      <span class="home-hero__terrain home-hero__terrain--south"></span>
      <span class="home-hero__grain"></span>
      <span class="home-hero__glow home-hero__glow--primary"></span>
      <span class="home-hero__glow home-hero__glow--secondary"></span>
    </div>

    <div class="container home-hero__inner">
      <div class="home-hero__copy" data-reveal>
        <p class="home-hero__eyebrow">{hero.label}</p>
        <p class="home-hero__brand">{siteMeta.name}</p>
        <h1 class="home-hero__title">
          {hero.lead} <em>{hero.emphasis}</em> {hero.tail}
        </h1>
        <p class="home-hero__summary">{hero.summary}</p>

        <div class="hero__actions">
          <a class="button button--primary" href={hero.primaryAction.href}>
            {hero.primaryAction.label}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a class="button button--secondary" href={hero.secondaryAction.href}>
            {hero.secondaryAction.label}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 17 17 7M17 7H8M17 7v9"></path>
            </svg>
          </a>
        </div>

        {latestUpdate && (
          <p class="home-hero__microcopy">
            <span>Last platform update</span>
            <a href="#updates">{latestUpdateMonthLabel}</a>
          </p>
        )}

        <dl class="home-hero__proof">
          {
            hero.metrics.map((metric) => (
              <div class="home-hero__proof-item">
                <dt>{metric.label}</dt>
                <dd>{metric.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="home-hero__stage" data-reveal>
        <div class="home-hero__stage-header">
          <h2 class="home-hero__stage-title">Active operating corridors</h2>
          <span>Operator-led assets in Kenya and Saudi Arabia, with a broader pipeline underway.</span>
        </div>

        <div class="home-hero__market-list">
          {
            regions.markets.map((market) => (
              <article class:list={['home-hero__market', `home-hero__market--${market.theme}`]}>
                <div class="home-hero__market-top">
                  <p class="home-hero__market-status">
                    <span></span>
                    {market.status}
                  </p>
                  <h3>{market.name}</h3>
                </div>
                <ul class="home-hero__market-details">
                  {market.detail.map((item) => (
                    <li>
                      <span>{item.label}</span>
                      <strong>{item.value}</strong>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>

        <div class="home-hero__loop">
          <h3 class="home-hero__loop-title">Operating loop</h3>
          <ol>
            {
              hero.flywheel.map((step, index) => (
                <li>
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <strong>{step}</strong>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section class="signal-strip">
    <div class="container signal-strip__inner">
      <p class="signal-strip__title">Affiliations and standards</p>
      <div class="signal-strip__list">
        {
          affiliations.map((item) => (
            <div class="signal-strip__item" data-reveal>
              <strong>{item.label}</strong>
              <span>{item.detail}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section activity-section" id="updates">
    <div class="container">
      <div class="activity-section__header">
        <SectionIntro
          label="Latest Activity"
          title="The platform is active now, not archival."
          intro={`Last updated ${latestUpdateMonthLabel}. These are the most recent milestones across BRG's operating platform.`}
        />
        {latestUpdate && (
          <div class="activity-section__stamp" data-reveal>
            <span>Latest milestone</span>
            <strong>{latestUpdateFullLabel}</strong>
            <p>{latestUpdate.data.category}</p>
          </div>
        )}
      </div>
      <div class="updates-grid updates-grid--activity">
        {updates.map((update, index) => <UpdateCard update={update} featured={index === 0} />)}
      </div>
    </div>
  </section>

  <section class="section section--tinted pathways-section" id="pathways">
    <div class="container">
      <div class="section-heading-row">
        <SectionIntro
          label="Start Here"
          title="Choose the path that matches your role."
          intro="BRG is built for capital partners, carbon buyers, and infrastructure operators who need a real operating platform."
        />
        <p class="pathways-section__note">Each path leads straight to the right team.</p>
      </div>
      <div class="pathways-grid">
        {
          contact.audiences.map((audience, index) => (
            <a class="pathway-card" href={audience.href} data-reveal>
              <span class="pathway-card__index">{String(index + 1).padStart(2, '0')}</span>
              <span class="pathway-card__audience">{audience.audience}</span>
              <h3>{audience.title}</h3>
              <p>{audience.description}</p>
              <span class="pathway-card__action">
                {audience.action}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7"></path>
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--tinted" id="platform">
    <div class="container">
      <SectionIntro label={platform.label} title={platform.title} intro={platform.intro} />
      <div class="platform-layout">
        <div class="platform-layout__narrative" data-reveal>
          {platform.narrative.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="stacked-list">
          {
            platform.capabilities.map((capability, index) => (
              <article class="stacked-list__item" data-reveal>
                <span class="stacked-list__index">{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <h3>{capability.title}</h3>
                  <p>{capability.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="model">
    <div class="container">
      <SectionIntro
        label={commercialModel.label}
        title={commercialModel.title}
        intro={commercialModel.intro}
      />
      <div class="model-lines">
        {
          commercialModel.lines.map((line, index) => (
            <article class="model-line" data-reveal>
              <div class="model-line__lead">
                <span class="model-line__index">{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <p class="model-line__phase">{line.phase}</p>
                  <h3>{line.title}</h3>
                </div>
              </div>
              <p class="model-line__description">{line.description}</p>
              <ul class="model-line__revenue">
                {line.revenue.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--tinted" id="technology">
    <div class="container">
      <SectionIntro label={technology.label} title={technology.title} intro={technology.intro} />
      <div class="technology-grid">
        {
          technology.systems.map((system, index) => (
            <article
              class:list={[
                'technology-card',
                `technology-card--${system.theme}`,
                index === 0 && 'technology-card--featured',
              ]}
              data-reveal
            >
              <div class="technology-card__topline">
                <span class="technology-card__tag">{system.tag}</span>
                <div class="technology-card__signal">
                  <span>{system.specs[0]?.value}</span>
                  <strong>{system.specs[3]?.value}</strong>
                </div>
              </div>
              <div class="technology-card__body">
                <h3>{system.title}</h3>
                <p>{system.summary}</p>
                <dl class="technology-card__specs">
                  {system.specs.map((spec) => (
                    <div>
                      <dt>{spec.label}</dt>
                      <dd>{spec.value}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--dark" id="regions">
    <div class="container">
      <SectionIntro
        label={regions.label}
        title={regions.title}
        intro={regions.intro}
        tone="dark"
      />
      <div class="market-list">
        {
          regions.markets.map((market) => (
            <article class:list={['market-band', `market-band--${market.theme}`]} data-reveal>
              <div class="market-band__visual">
                <div class="market-band__visual-copy">
                  <span>{market.detail[0]?.value}</span>
                  <strong>{market.detail[2]?.value}</strong>
                </div>
              </div>
              <div class="market-band__body">
                <p class="market-band__status">
                  <span></span>
                  {market.status}
                </p>
                <h3>{market.name}</h3>
                <p>{market.description}</p>
                <dl class="market-band__details">
                  {market.detail.map((item) => (
                    <div>
                      <dt>{item.label}</dt>
                      <dd>{item.value}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            </article>
          ))
        }
      </div>

      <div class="expansion-banner" data-reveal>
        <div>
          <h3>{regions.expansion.title}</h3>
          <p>{regions.expansion.description}</p>
        </div>
        <div class="expansion-banner__chips">
          {regions.expansion.regions.map((label) => <span>{label}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tinted" id="impact">
    <div class="container">
      <div class="proof-shell">
        <div class="proof-shell__lead">
          <SectionIntro label={impact.label} title={impact.title} intro={impact.intro} />
          <div class="impact-layout__narrative" data-reveal>
            {impact.narrative.map((paragraph) => <p>{paragraph}</p>)}
          </div>
          <div class="proof-shell__operator" data-reveal>
            <p class="proof-shell__label">{leadership.label}</p>
            <h3>{leadership.title}</h3>
            {leadership.narrative.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
        <div class="impact-stats">
          {
            impact.stats.map((stat) => (
              <article class="impact-stats__item" data-reveal>
                <strong>{stat.value}</strong>
                <h3>{stat.label}</h3>
                <p>{stat.description}</p>
              </article>
            ))
          }
        </div>
      </div>
      <div class="principles-shell" data-reveal>
        <div class="principles-shell__intro">
          <p class="proof-shell__label">Operating principles</p>
          <h3>{leadership.intro}</h3>
        </div>
        <div class="principles principles--grid">
          {
            leadership.principles.map((principle) => (
              <article class="principles__item" data-reveal>
                <span class="principles__bar" aria-hidden="true"></span>
                <div>
                  <h3>{principle.title}</h3>
                  <p>{principle.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section" id="contact">
    <div class="container">
      <div class="cta-panel" data-reveal>
        <SectionIntro
          label={contact.label}
          title={contact.title}
          intro={contact.intro}
          tone="dark"
        />
        <div class="cta-panel__actions">
          <a class="button button--primary" href={`mailto:${siteMeta.email}`}>
            Email BRG
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a class="button button--secondary" href="#pathways">
            Choose your path
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 17 17 7M17 7H8M17 7v9"></path>
            </svg>
          </a>
        </div>
        <div class="cta-panel__contacts">
          {
            contact.audiences.map((audience) => (
              <a class="cta-panel__contact" href={audience.href}>
                <span>{audience.audience}</span>
                <strong>{audience.action}</strong>
              </a>
            ))
          }
        </div>
        <div class="cta-section__footer">
          <span>General inquiries</span>
          <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
