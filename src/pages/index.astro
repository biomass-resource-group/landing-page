---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageCta from '../components/PageCta.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { formatFullDate, formatMonthYear } from '../utils/formatDate';
import {
  commercialModel,
  exploreLinks,
  hero,
  regions,
  siteMeta,
} from '../data/site';

const updates = (await getCollection('updates', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const latestUpdate = updates[0];
const remainingUpdates = updates.slice(1);
const latestUpdateMonthLabel = latestUpdate ? formatMonthYear(latestUpdate.data.publishedAt) : '';
const latestUpdateFullLabel = latestUpdate ? formatFullDate(latestUpdate.data.publishedAt) : '';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: siteMeta.title,
  url: siteMeta.siteUrl,
  description: siteMeta.description,
};
---

<BaseLayout
  title={siteMeta.title}
  description={siteMeta.description}
  structuredData={structuredData}
  bodyClass="page--home"
>
  <section class="home-hero" data-hero>
    <div class="home-hero__backdrop" aria-hidden="true">
      <span class="home-hero__terrain home-hero__terrain--north"></span>
      <span class="home-hero__terrain home-hero__terrain--south"></span>
      <span class="home-hero__grain"></span>
      <span class="home-hero__glow home-hero__glow--primary"></span>
      <span class="home-hero__glow home-hero__glow--secondary"></span>
    </div>

    <div class="container home-hero__inner">
      <div class="home-hero__copy" data-reveal>
        <p class="home-hero__eyebrow">{hero.label}</p>
        <p class="home-hero__brand">{siteMeta.name}</p>
        <h1 class="home-hero__title">
          {hero.lead} <em>{hero.emphasis}</em> {hero.tail}
        </h1>
        <p class="home-hero__summary">{hero.summary}</p>

        <div class="hero__actions">
          <a class="button button--primary" href={hero.primaryAction.href}>
            {hero.primaryAction.label}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a class="button button--secondary" href={hero.secondaryAction.href}>
            {hero.secondaryAction.label}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 17 17 7M17 7H8M17 7v9"></path>
            </svg>
          </a>
        </div>

        {latestUpdate && (
          <p class="home-hero__microcopy">
            <span>Latest milestone</span>
            <a href="/updates/">{latestUpdateMonthLabel}</a>
          </p>
        )}
      </div>

      <div class="home-hero__stage" data-reveal>
        <div class="home-hero__stage-header">
          <h2 class="home-hero__stage-title">Operating today</h2>
          <span>Two live corridors, three revenue layers, and a broader pipeline already underway.</span>
        </div>

        <div class="home-hero__market-list">
          {
            regions.markets.map((market) => (
              <article class:list={['home-hero__market', `home-hero__market--${market.theme}`]}>
                <div class="home-hero__market-top">
                  <p class="home-hero__market-status">
                    <span></span>
                    {market.status}
                  </p>
                  <h3>{market.name}</h3>
                </div>
                <ul class="home-hero__market-details">
                  {market.detail.map((item) => (
                    <li>
                      <span>{item.label}</span>
                      <strong>{item.value}</strong>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>

        {latestUpdate && (
          <a class="home-hero__milestone" href={`/updates/${latestUpdate.id}/`}>
            <span>Latest update</span>
            <strong>{latestUpdate.data.title}</strong>
            <p>
              {latestUpdateFullLabel} · {latestUpdate.data.category}
            </p>
          </a>
        )}
      </div>
    </div>
  </section>

  <section class="section home-destinations">
    <div class="container">
      <div class="section-heading-row">
        <SectionIntro
          label="Explore BRG"
          title="Follow the page that matches the question."
          intro="The homepage stays brief. Deeper platform detail, market context, and company proof now live on dedicated pages."
        />
      </div>
      <div class="destination-list">
        {
          exploreLinks.map((link, index) => (
            <a class="destination-link" href={link.href} data-reveal>
              <span class="destination-link__index">{String(index + 1).padStart(2, '0')}</span>
              <div class="destination-link__body">
                <p class="destination-link__label">{link.label}</p>
                <h3>{link.title}</h3>
                <p>{link.description}</p>
              </div>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 17 17 7M17 7H8M17 7v9"></path>
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--tinted home-activity-preview">
    <div class="container">
      <div class="section-heading-row">
        <SectionIntro
          label="Latest Activity"
          title="Recent movement across the operating platform."
          intro={`Last updated ${latestUpdateMonthLabel}. The current signals live here, with the full archive on the updates page.`}
        />
        <a class="section-heading-row__link" href="/updates/">
          View all updates
        </a>
      </div>

      <div class="activity-preview">
        {
          latestUpdate && (
            <a class="activity-preview__feature" href={`/updates/${latestUpdate.id}/`} data-reveal>
              <div class="activity-preview__meta">
                <span>{latestUpdate.data.category}</span>
                <time datetime={latestUpdate.data.publishedAt.toISOString()}>{latestUpdateFullLabel}</time>
              </div>
              <h3>{latestUpdate.data.title}</h3>
              <p>{latestUpdate.data.summary}</p>
              <span class="activity-preview__action">Read the update</span>
            </a>
          )
        }

        <div class="activity-preview__rail">
          {
            remainingUpdates.map((update) => (
              <a class="activity-preview__item" href={`/updates/${update.id}/`} data-reveal>
                <div class="activity-preview__meta">
                  <span>{update.data.category}</span>
                  <time datetime={update.data.publishedAt.toISOString()}>
                    {formatFullDate(update.data.publishedAt)}
                  </time>
                </div>
                <h3>{update.data.title}</h3>
                <p>{update.data.summary}</p>
              </a>
            ))
          }
          <a class="activity-preview__browse" href="/updates/" data-reveal>
            Browse the full updates archive
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-model-preview">
    <div class="container">
      <div class="section-heading-row">
        <SectionIntro
          label={commercialModel.label}
          title="One asset, three aligned revenue layers."
          intro="BRG projects are designed to monetize waste processing, biochar product output, and carbon removal rather than relying on a single market."
        />
        <a class="section-heading-row__link" href="/platform/">
          See the full operating model
        </a>
      </div>

      <div class="home-model-preview__grid">
        {
          commercialModel.lines.map((line, index) => (
            <article class="home-model-preview__item" data-reveal>
              <span class="home-model-preview__index">{String(index + 1).padStart(2, '0')}</span>
              <p class="home-model-preview__phase">{line.phase}</p>
              <h3>{line.title}</h3>
              <p>{line.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <PageCta
    label="Contact"
    title="Bring the right BRG team into the conversation."
    intro="Investor, carbon buyer, and operating-partner routes now live on a dedicated contact page."
    primaryAction={{ label: 'Open contact page', href: '/contact/' }}
    secondaryAction={{ label: 'Review markets', href: '/markets/', variant: 'secondary' }}
  />
</BaseLayout>
