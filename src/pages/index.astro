---
import AudiencePathCard from '../components/AudiencePathCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import EvidenceNote from '../components/EvidenceNote.astro';
import MetricCard from '../components/MetricCard.astro';
import PageCta from '../components/PageCta.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import RevenueStack from '../components/RevenueStack.astro';
import SectionIntro from '../components/SectionIntro.astro';
import StatusBadge from '../components/StatusBadge.astro';
import {
  audiencePaths,
  commercialModel,
  glossary,
  home,
  marketCorridors,
  pageMeta,
  siteMeta,
  verification,
} from '../data/site';

const meta = pageMeta.home;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  path={meta.path}
  structuredData={structuredData}
  bodyClass="page--home"
>
  <section class="home-hero" data-hero>
    <div class="home-hero__backdrop" aria-hidden="true">
      <span class="home-hero__grain"></span>
    </div>
    <div class="container home-hero__inner">
      <div class="home-hero__copy" data-reveal>
        <p class="home-hero__eyebrow">{home.hero.label}</p>
        <h1 class="home-hero__title">{home.hero.title}</h1>
        <p class="home-hero__summary">{home.hero.summary}</p>
        <div class="hero__actions">
          <a class="button button--primary" href={home.hero.primaryAction.href}>{home.hero.primaryAction.label}</a>
          <a class="button button--secondary" href={home.hero.secondaryAction.href}>{home.hero.secondaryAction.label}</a>
        </div>
        <dl class="home-hero__proof">
          {
            home.hero.metrics.map((metric) => (
              <div class="home-hero__proof-item">
                <dt>{metric.label}</dt>
                <dd class="home-hero__proof-value">{metric.value}</dd>
                <dd class="home-hero__proof-status">{metric.status}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <section class="section" id="what-brg-does">
    <div class="container">
      <SectionIntro label={home.whatWeDo.label} title={home.whatWeDo.title} intro={home.whatWeDo.intro} />
      <ProcessFlow steps={home.whatWeDo.steps} />
      <div class="glossary-strip" aria-label="Glossary">
        <details>
          <summary>Biochar</summary>
          <p>{glossary.biochar}</p>
        </details>
        <details>
          <summary>Pyrolysis</summary>
          <p>{glossary.pyrolysis}</p>
        </details>
        <details>
          <summary>MRV</summary>
          <p>{glossary.mrv}</p>
        </details>
      </div>
    </div>
  </section>

  <section class="section section--tinted" id="pathways">
    <div class="container">
      <SectionIntro
        label={home.audienceIntro.label}
        title={home.audienceIntro.title}
        intro={home.audienceIntro.intro}
      />
      <div class="card-grid card-grid--three">
        {
          audiencePaths.map((path) => (
            <AudiencePathCard
              audience={path.audience}
              title={path.title}
              description={path.description}
              href={path.href}
              cta={path.cta}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="operating-proof">
    <div class="container">
      <SectionIntro label={home.proof.label} title={home.proof.title} intro={home.proof.intro} />
      <div class="proof-summary">
        {
          marketCorridors.map((corridor) => (
            <article class="proof-summary__card" data-reveal>
              <div class="proof-summary__header">
                <h3>{corridor.name}</h3>
                <StatusBadge status={corridor.status} label={corridor.statusLabel} />
              </div>
              <dl class="definition-grid definition-grid--compact">
                <div><dt>Entity</dt><dd>{corridor.operatingEntity}</dd></div>
                <div><dt>Feedstock</dt><dd>{corridor.feedstock}</dd></div>
                <div><dt>Technology</dt><dd>{corridor.technology}</dd></div>
                <div><dt>Verification</dt><dd>{corridor.carbonPathway}</dd></div>
              </dl>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--dark" id="platform-scales">
    <div class="container">
      <SectionIntro label={home.scale.label} title={home.scale.title} intro={home.scale.intro} tone="dark" />
      <RevenueStack lines={commercialModel.lines} caveat={commercialModel.caveat} />
      <EvidenceNote
        title="Claim language"
        status="verificationReady"
        text={verification.claimLanguage}
      />
    </div>
  </section>

  <section class="section section--tinted" id="home-metrics">
    <div class="container">
      <div class="metric-row">
        {
          home.hero.metrics.map((metric) => (
            <MetricCard
              value={metric.value}
              label={metric.label}
              note={metric.status}
              status={metric.label.includes('pipeline') ? 'pipeline' : metric.label.includes('durability') ? 'tested' : 'operational'}
            />
          ))
        }
      </div>
    </div>
  </section>

  <PageCta
    label={home.finalCta.label}
    title={home.finalCta.title}
    intro={home.finalCta.intro}
    primaryAction={home.finalCta.primaryAction}
    secondaryAction={home.finalCta.secondaryAction}
  />
</BaseLayout>
