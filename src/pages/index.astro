---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageCta from '../components/PageCta.astro';
import SectionIntro from '../components/SectionIntro.astro';
import {
  about,
  commercialModel,
  exploreLinks,
  hero,
  regions,
  siteMeta,
} from '../data/site';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: siteMeta.title,
  url: siteMeta.siteUrl,
  description: siteMeta.description,
};
---

<BaseLayout
  title={siteMeta.title}
  description={siteMeta.description}
  structuredData={structuredData}
  bodyClass="page--home"
>
  <section class="home-hero" data-hero>
    <div class="home-hero__backdrop" aria-hidden="true">
      <span class="home-hero__terrain home-hero__terrain--north"></span>
      <span class="home-hero__terrain home-hero__terrain--south"></span>
      <span class="home-hero__grain"></span>
      <span class="home-hero__glow home-hero__glow--primary"></span>
      <span class="home-hero__glow home-hero__glow--secondary"></span>
    </div>

    <div class="container home-hero__inner">
      <div class="home-hero__copy" data-reveal>
        <p class="home-hero__eyebrow">{hero.label}</p>
        <p class="home-hero__brand">{siteMeta.name}</p>
        <h1 class="home-hero__title">
          {hero.lead} <em>{hero.emphasis}</em> {hero.tail}
        </h1>
        <p class="home-hero__summary">{hero.summary}</p>

        <div class="hero__actions">
          <a class="button button--primary" href={hero.primaryAction.href}>
            {hero.primaryAction.label}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a class="button button--secondary" href={hero.secondaryAction.href}>
            {hero.secondaryAction.label}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 17 17 7M17 7H8M17 7v9"></path>
            </svg>
          </a>
        </div>

        <dl class="home-hero__proof">
          {
            hero.metrics.map((metric) => (
              <div class="home-hero__proof-item">
                <dt>{metric.label}</dt>
                <dd>{metric.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="home-hero__stage" data-reveal>
        <div class="home-hero__stage-header">
          <h2 class="home-hero__stage-title">Operating today</h2>
          <span>Two live corridors, three revenue layers, and a broader pipeline already underway.</span>
        </div>

        <div class="home-hero__loop">
          <p class="home-hero__loop-title">Operating flow</p>
          <ol>
            {
              hero.flywheel.map((step, index) => (
                <li>
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <strong>{step}</strong>
                </li>
              ))
            }
          </ol>
        </div>

        <div class="home-hero__market-list">
          {
            regions.markets.map((market) => (
              <article class:list={['home-hero__market', `home-hero__market--${market.theme}`]}>
                <div class="home-hero__market-top">
                  <p class="home-hero__market-status">
                    <span></span>
                    {market.status}
                  </p>
                  <h3>{market.name}</h3>
                </div>
                <ul class="home-hero__market-details">
                  {market.detail.map((item) => (
                    <li>
                      <span>{item.label}</span>
                      <strong>{item.value}</strong>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>

      </div>
    </div>
  </section>

  <section class="section home-model-preview">
    <div class="container">
      <div class="section-heading-row">
        <SectionIntro
          label={commercialModel.label}
          title="One asset, three aligned revenue layers."
          intro="BRG projects are designed to monetize biochar product output, carbon removal, and kiln technology sales and licensing rather than relying on a single market."
        />
      </div>

      <div class="home-model-preview__grid">
        {
          commercialModel.lines.map((line, index) => (
            <article class="home-model-preview__item" data-reveal>
              <span class="home-model-preview__index">{String(index + 1).padStart(2, '0')}</span>
              <p class="home-model-preview__phase">{line.phase}</p>
              <h3>{line.title}</h3>
              <p>{line.description}</p>
              <ul class="home-model-preview__revenue">
                {line.revenue.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--tinted home-about-preview">
    <div class="container">
      <div class="home-about-preview__shell">
        <div class="home-about-preview__lead">
          <SectionIntro
            label={about.label}
            title={about.title}
            intro={about.intro}
          />
          <div class="about-highlights">
            {
              about.highlights.map((item) => (
                <article class="about-highlight" data-reveal>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </article>
              ))
            }
          </div>
          <div class="home-about-preview__actions" data-reveal>
            <a class="button button--primary" href="/about/">
              Meet the leadership
            </a>
          </div>
        </div>

        <div class="leadership-spotlight leadership-spotlight--home">
          {
            about.team.map((person) => {
              const initials = person.name
                .split(' ')
                .map((part) => part[0])
                .join('')
                .slice(0, 2);

              return (
                <article
                  class:list={[
                    'leadership-card',
                    person.featured && 'leadership-card--featured',
                  ]}
                  data-reveal
                >
                  <div class="leadership-card__topline">
                    <div class="leadership-card__avatar" aria-hidden="true">
                      {initials}
                    </div>
                    <div class="leadership-card__identity">
                      <span>{person.focus}</span>
                      <h3>{person.name}</h3>
                      <p>{person.role}</p>
                    </div>
                  </div>
                  <p class="leadership-card__summary">{person.summary}</p>
                  <a
                    class="leadership-card__link"
                    href={person.href}
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`${person.name} on LinkedIn`}
                  >
                    LinkedIn
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M7 17 17 7M17 7H8M17 7v9"></path>
                    </svg>
                  </a>
                </article>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section home-destinations">
    <div class="container">
      <div class="section-heading-row">
        <SectionIntro
          label="Evaluate BRG"
          title="Move next to the page that answers the diligence question."
          intro="The operating model, active markets, and company proof now live on focused pages instead of one crowded homepage."
        />
      </div>
      <div class="destination-list">
        {
          exploreLinks.map((link, index) => (
            <a class="destination-link" href={link.href} data-reveal>
              <span class="destination-link__index">{String(index + 1).padStart(2, '0')}</span>
              <div class="destination-link__body">
                <p class="destination-link__label">{link.label}</p>
                <h3>{link.title}</h3>
                <p>{link.description}</p>
              </div>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 17 17 7M17 7H8M17 7v9"></path>
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <PageCta
    label="Contact"
    title="Bring the right BRG team into the conversation."
    intro="BRG routes investor, carbon buyer, and operating-partner conversations to the team that can act on them."
    primaryAction={{ label: 'Open contact page', href: '/contact/' }}
    secondaryAction={{ label: 'About BRG', href: '/about/', variant: 'secondary' }}
  />
</BaseLayout>
