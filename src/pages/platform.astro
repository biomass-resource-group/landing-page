---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvidenceNote from '../components/EvidenceNote.astro';
import PageCta from '../components/PageCta.astro';
import PageHero from '../components/PageHero.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import RevenueStack from '../components/RevenueStack.astro';
import SectionIntro from '../components/SectionIntro.astro';
import {
  commercialModel,
  pageMeta,
  platformPage,
  siteMeta,
  verification,
} from '../data/site';

const meta = pageMeta.platform;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={platformPage.hero.label}
    title={platformPage.hero.title}
    intro={platformPage.hero.intro}
    actions={[platformPage.hero.primaryAction, platformPage.hero.secondaryAction]}
    compact
  />

  <section class="section" id="operating-model">
    <div class="container">
      <SectionIntro
        label={platformPage.process.label}
        title={platformPage.process.title}
        intro={platformPage.process.intro}
      />
      <ProcessFlow steps={platformPage.process.steps} />
    </div>
  </section>

  <section class="section section--dark" id="revenue-stack">
    <div class="container">
      <SectionIntro label={commercialModel.label} title={commercialModel.title} intro={commercialModel.intro} tone="dark" />
      <RevenueStack lines={commercialModel.lines} caveat={commercialModel.caveat} />
    </div>
  </section>

  <section class="section" id="standards">
    <div class="container">
      <SectionIntro
        label={platformPage.standards.label}
        title={platformPage.standards.title}
        intro={platformPage.standards.intro}
      />
      <EvidenceNote
        title="Verification posture"
        status="verificationReady"
        text={verification.claimLanguage}
      />
    </div>
  </section>

  <PageCta
    label={platformPage.finalCta.label}
    title={platformPage.finalCta.title}
    intro={platformPage.finalCta.intro}
    primaryAction={platformPage.finalCta.primaryAction}
    secondaryAction={platformPage.finalCta.secondaryAction}
  />
</BaseLayout>
