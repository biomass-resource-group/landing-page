---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageCta from '../components/PageCta.astro';
import PageHero from '../components/PageHero.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { pageMeta, platformPage, siteMeta } from '../data/site';

const meta = pageMeta.platform;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={platformPage.hero.label}
    title={platformPage.hero.title}
    intro={platformPage.hero.intro}
    actions={[platformPage.hero.primaryAction, platformPage.hero.secondaryAction]}
    meta={platformPage.hero.meta}
    compact
  />

  <section class="section" id="operating-model">
    <div class="container">
      <SectionIntro
        label={platformPage.process.label}
        title={platformPage.process.title}
        intro={platformPage.process.intro}
      />
      <ProcessFlow steps={platformPage.process.steps} />
    </div>
  </section>

  <section class="section section--tinted" id="technology-fit">
    <div class="container">
      <SectionIntro
        label={platformPage.technology.label}
        title={platformPage.technology.title}
        intro={platformPage.technology.intro}
      />
      <ul class="tech-fit" data-reveal>
        {
          platformPage.technology.items.map((item, index) => (
            <li class="tech-fit__block">
              <span class="tech-fit__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <h3 class="tech-fit__title">{item.title}</h3>
              <p class="tech-fit__text">{item.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section" id="review-posture">
    <div class="container narrow">
      <div class="review-posture" data-reveal>
        <p class="review-posture__label">{platformPage.reviewPosture.label}</p>
        <h2 class="review-posture__title">{platformPage.reviewPosture.title}</h2>
        <p class="review-posture__text">{platformPage.reviewPosture.text}</p>
      </div>
    </div>
  </section>

  <PageCta
    label={platformPage.finalCta.label}
    title={platformPage.finalCta.title}
    intro={platformPage.finalCta.intro}
    primaryAction={platformPage.finalCta.primaryAction}
    secondaryAction={platformPage.finalCta.secondaryAction}
  />
</BaseLayout>
