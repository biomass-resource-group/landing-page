---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvidenceNote from '../components/EvidenceNote.astro';
import OperatingBoundaryPanel from '../components/OperatingBoundaryPanel.astro';
import PageCta from '../components/PageCta.astro';
import PageHero from '../components/PageHero.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import ProjectOutputs from '../components/ProjectOutputs.astro';
import SectionIntro from '../components/SectionIntro.astro';
import TechnologyStack from '../components/TechnologyStack.astro';

import {
  pageMeta,
  platformPage,
  projectModel,
  siteMeta,
  verification,
} from '../data/site';

const meta = pageMeta.platform;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={platformPage.hero.label}
    title={platformPage.hero.title}
    intro={platformPage.hero.intro}
    actions={[platformPage.hero.primaryAction, platformPage.hero.secondaryAction]}
    compact
  />

  <section class="section" id="owner-operated">
    <div class="container">
      <SectionIntro
        label={platformPage.ownership.label}
        title={platformPage.ownership.title}
        intro={platformPage.ownership.intro}
      />
      <OperatingBoundaryPanel layers={platformPage.ownership.layers} />
    </div>
  </section>

  <section class="section" id="operating-model">
    <div class="container">
      <SectionIntro
        label={platformPage.process.label}
        title={platformPage.process.title}
        intro={platformPage.process.intro}
      />
      <ProcessFlow steps={platformPage.process.steps} />
    </div>
  </section>

  <section class="section section--tinted" id="technology-approach">
    <div class="container">
      <SectionIntro
        label={platformPage.technology.label}
        title={platformPage.technology.title}
        intro={platformPage.technology.intro}
      />
      <TechnologyStack systems={platformPage.technology.systems} />
    </div>
  </section>

  <section class="section section--dark" id="project-outputs">
    <div class="container">
      <SectionIntro label={projectModel.label} title={projectModel.title} intro={projectModel.intro} tone="dark" />
      <ProjectOutputs lines={projectModel.lines} caveat={projectModel.caveat} />
    </div>
  </section>

  <section class="section" id="standards">
    <div class="container">
      <SectionIntro
        label={platformPage.standards.label}
        title={platformPage.standards.title}
        intro={platformPage.standards.intro}
      />
      <div class="card-grid card-grid--three">
        {
          platformPage.standards.notes.map((note) => (
            <EvidenceNote title={note.title} status={note.status} text={note.text} />
          ))
        }
      </div>
      <p class="section-note">{verification.claimLanguage}</p>
    </div>
  </section>

  <PageCta
    label={platformPage.finalCta.label}
    title={platformPage.finalCta.title}
    intro={platformPage.finalCta.intro}
    primaryAction={platformPage.finalCta.primaryAction}
    secondaryAction={platformPage.finalCta.secondaryAction}
  />
</BaseLayout>
