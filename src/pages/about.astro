---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClaimStatus from '../components/ClaimStatus.astro';
import EvidenceNote from '../components/EvidenceNote.astro';
import MetricCard from '../components/MetricCard.astro';
import PageCta from '../components/PageCta.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import {
  aboutPage,
  evidenceMetrics,
  leadership,
  operatingPrinciples,
  pageMeta,
  siteMeta,
  verification,
} from '../data/site';

const meta = pageMeta.about;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: meta.title,
    url: `${siteMeta.siteUrl}${meta.path}`,
    description: meta.description,
  },
  ...leadership.map((person) => ({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: person.name,
    jobTitle: person.role,
    ...(person.href ? { url: person.href, sameAs: [person.href] } : {}),
    worksFor: {
      '@type': 'Organization',
      name: siteMeta.name,
      url: siteMeta.siteUrl,
    },
  })),
];
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={aboutPage.hero.label}
    title={aboutPage.hero.title}
    intro={aboutPage.hero.intro}
    actions={[aboutPage.hero.primaryAction, aboutPage.hero.secondaryAction]}
    meta={aboutPage.hero.meta}
    compact
  />

  <section class="section section--tinted" id="story">
    <div class="container narrow">
      <SectionIntro label={aboutPage.story.label} title={aboutPage.story.title} intro={aboutPage.story.intro} />
      <div class="prose-block" data-reveal>
        {aboutPage.story.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section" id="leadership">
    <div class="container">
      <SectionIntro
        label={aboutPage.leadership.label}
        title={aboutPage.leadership.title}
        intro={aboutPage.leadership.intro}
      />
      <div class="leadership-grid">
        {
          leadership.map((person) => {
            const initials = person.name
              .split(' ')
              .map((part) => part[0])
              .join('')
              .slice(0, 2);

            return (
              <article class="leadership-card" data-reveal>
                <div class="leadership-card__topline">
                  <div class="leadership-card__avatar" aria-hidden="true">{initials}</div>
                  <div>
                    <h3>{person.name}</h3>
                    <p>{person.role}</p>
                  </div>
                </div>
                <ul class="tag-list" aria-label={`${person.name} focus areas`}>
                  {person.focus.map((item) => <li>{item}</li>)}
                </ul>
                <div class="leadership-card__bio">
                  {person.bio.map((paragraph) => <p>{paragraph}</p>)}
                </div>
                {
                  person.href && (
                    <a class="text-action" href={person.href} target="_blank" rel="noreferrer" aria-label={`${person.name} on LinkedIn`}>
                      LinkedIn
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 12h14M13 5l7 7-7 7"></path>
                      </svg>
                    </a>
                  )
                }
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="section section--dark" id="standards">
    <div class="container">
      <SectionIntro
        label={aboutPage.standards.label}
        title={aboutPage.standards.title}
        intro={aboutPage.standards.intro}
        tone="dark"
      />
      <div class="card-grid card-grid--two">
        {
          verification.pathways.map((pathway) => (
            <EvidenceNote title={pathway.label} status={pathway.status} text={`${pathway.detail} ${pathway.evidenceNote}`} />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--tinted" id="evidence">
    <div class="container">
      <SectionIntro
        label={aboutPage.evidence.label}
        title={aboutPage.evidence.title}
        intro={aboutPage.evidence.intro}
      />
      <div class="metric-row">
        {
          evidenceMetrics.map((metric) => (
            <MetricCard value={metric.value} label={metric.label} note={metric.note} status={metric.status} />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="principles">
    <div class="container">
      <SectionIntro
        label={aboutPage.principles.label}
        title={aboutPage.principles.title}
        intro={aboutPage.principles.intro}
      />
      <div class="card-grid card-grid--four">
        {
          operatingPrinciples.map((principle) => (
            <article class="principle-card" data-reveal>
              <ClaimStatus status="operational" />
              <h3>{principle.title}</h3>
              <p>{principle.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <PageCta
    label={aboutPage.finalCta.label}
    title={aboutPage.finalCta.title}
    intro={aboutPage.finalCta.intro}
    primaryAction={aboutPage.finalCta.primaryAction}
    secondaryAction={aboutPage.finalCta.secondaryAction}
  />
</BaseLayout>
