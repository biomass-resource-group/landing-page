---
import BaseLayout from '../layouts/BaseLayout.astro';
import EditorialPanel from '../components/EditorialPanel.astro';
import EvidenceNote from '../components/EvidenceNote.astro';
import PageCta from '../components/PageCta.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import {
  aboutPage,
  leadership,
  operatingPrinciples,
  pageMeta,
  siteMeta,
  verification,
} from '../data/site';

const meta = pageMeta.about;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: meta.title,
    url: `${siteMeta.siteUrl}${meta.path}`,
    description: meta.description,
  },
  ...leadership.map((person) => ({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: person.name,
    jobTitle: person.role,
    ...(person.href ? { url: person.href, sameAs: [person.href] } : {}),
    worksFor: {
      '@type': 'Organization',
      name: siteMeta.name,
      url: siteMeta.siteUrl,
    },
  })),
];

---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={aboutPage.hero.label}
    title={aboutPage.hero.title}
    intro={aboutPage.hero.intro}
    actions={[aboutPage.hero.primaryAction, aboutPage.hero.secondaryAction]}
    compact
  />

  <section class="section" id="operating-story">
    <div class="container">
      <SectionIntro
        label={aboutPage.story.label}
        title={aboutPage.story.title}
        intro={aboutPage.story.intro}
      />
      <EditorialPanel
        paragraphs={aboutPage.story.paragraphs}
        context={aboutPage.story.context}
        contextTitle="At a glance"
      />
    </div>
  </section>

  <section class="section" id="leadership">
    <div class="container">
      <SectionIntro
        label={aboutPage.leadership.label}
        title={aboutPage.leadership.title}
        intro={aboutPage.leadership.intro}
      />
      <div class="leadership-grid">
        {
          leadership.map((person) => {
            const initials = person.name
              .split(/\s+/)
              .map((part) => part.charAt(0).toUpperCase())
              .join('')
              .slice(0, 2);

            return (
              <article class="leadership" data-reveal>
                <div class="leadership__head">
                  <span class="leadership__monogram" aria-hidden="true">{initials}</span>
                  <div class="leadership__identity">
                    <h3>{person.name}</h3>
                    <p>{person.role}</p>
                  </div>
                </div>
                <ul class="leadership__focus" aria-label={`${person.name} focus areas`}>
                  {person.focus.map((item) => <li>{item}</li>)}
                </ul>
                <div class="leadership__bio">
                  {person.bio.map((paragraph) => <p>{paragraph}</p>)}
                </div>
                {
                  person.href && (
                    <a class="leadership__link" href={person.href} target="_blank" rel="noreferrer" aria-label={`${person.name} on LinkedIn`}>
                      LinkedIn
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 12h14M13 5l7 7-7 7"></path>
                      </svg>
                    </a>
                  )
                }
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="section section--tinted" id="evidence">
    <div class="container">
      <SectionIntro
        label={aboutPage.evidence.label}
        title={aboutPage.evidence.title}
        intro={aboutPage.evidence.intro}
      />
      <div class="card-grid card-grid--three">
        <EvidenceNote
          title="Durability testing pathway"
          status="tested"
          text="Tied to EBC-aligned and H/Corg-style testing concepts. Not presented as a universal guarantee for every output."
        />
        <EvidenceNote
          title="Active operating contexts"
          status="operational"
          text="Mobile and fixed kiln operations are active in two distinct corridors. Verification and offtake advance per project."
        />
        <EvidenceNote
          title="Pipeline regions"
          status="pipeline"
          text="Pakistan, MENA, and Sub-Saharan Africa are tracked separately from active operating corridors."
        />
      </div>
    </div>
  </section>

  <section class="section" id="principles">
    <div class="container">
      <SectionIntro
        label={aboutPage.principles.label}
        title={aboutPage.principles.title}
        intro={aboutPage.principles.intro}
      />
      <ol class="doctrine" data-reveal>
        {
          operatingPrinciples.map((principle, index) => (
            <li class="doctrine__item">
              <span class="doctrine__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <div class="doctrine__copy">
                <h3>{principle.title}</h3>
                <p>{principle.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section section--tinted" id="verification">
    <div class="container">
      <SectionIntro
        label={aboutPage.standards.label}
        title={aboutPage.standards.title}
        intro={aboutPage.standards.intro}
      />
      <div class="card-grid card-grid--two">
        {
          verification.pathways.slice(0, 3).map((pathway) => (
            <EvidenceNote title={pathway.label} status={pathway.status} text={`${pathway.detail} ${pathway.evidenceNote}`} />
          ))
        }
      </div>
    </div>
  </section>

  <PageCta
    label={aboutPage.finalCta.label}
    title={aboutPage.finalCta.title}
    intro={aboutPage.finalCta.intro}
    primaryAction={aboutPage.finalCta.primaryAction}
    secondaryAction={aboutPage.finalCta.secondaryAction}
  />
</BaseLayout>
