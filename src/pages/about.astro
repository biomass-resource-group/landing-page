---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import {
  aboutPage,
  leadership,
  operatingPrinciples,
  pageMeta,
  siteMeta,
} from '../data/site';

const meta = pageMeta.about;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: meta.title,
    url: `${siteMeta.siteUrl}${meta.path}`,
    description: meta.description,
  },
  ...leadership.map((person) => ({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: person.name,
    jobTitle: person.role,
    ...(person.href ? { url: person.href, sameAs: [person.href] } : {}),
    worksFor: {
      '@type': 'Organization',
      name: siteMeta.name,
      url: siteMeta.siteUrl,
    },
  })),
];
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={aboutPage.hero.label}
    title={aboutPage.hero.title}
    intro={aboutPage.hero.intro}
    actions={[aboutPage.hero.primaryAction, aboutPage.hero.secondaryAction]}
    compact
  />

  <section class="section" id="operating-story">
    <div class="container narrow">
      <SectionIntro
        label={aboutPage.story.label}
        title={aboutPage.story.title}
        intro={aboutPage.story.intro}
      />
      <div class="story-prose" data-reveal>
        {aboutPage.story.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <dl class="story-rail" aria-label="At a glance">
        {
          aboutPage.story.context.map((item) => (
            <div class="story-rail__item">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section class="section section--tinted" id="leadership">
    <div class="container">
      <SectionIntro
        label={aboutPage.leadership.label}
        title={aboutPage.leadership.title}
        intro={aboutPage.leadership.intro}
      />
      <ul class="leadership-list" data-reveal>
        {
          leadership.map((person) => (
            <li class="leadership-row">
              <div class="leadership-row__identity">
                <h3>{person.name}</h3>
                <p class="leadership-row__role">{person.role}</p>
                <p class="leadership-row__focus">{person.focus.join(' · ')}</p>
              </div>
              <div class="leadership-row__bio">
                {person.bio.map((paragraph) => <p>{paragraph}</p>)}
                {
                  person.href && (
                    <a class="leadership-row__link" href={person.href} target="_blank" rel="noreferrer" aria-label={`${person.name} on LinkedIn`}>
                      LinkedIn
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 12h14M13 5l7 7-7 7"></path>
                      </svg>
                    </a>
                  )
                }
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section" id="principles">
    <div class="container">
      <SectionIntro
        label={aboutPage.principles.label}
        title={aboutPage.principles.title}
        intro={aboutPage.principles.intro}
      />
      <ul class="doctrine-list" data-reveal>
        {
          operatingPrinciples.map((principle, index) => (
            <li class="doctrine-list__item">
              <span class="doctrine-list__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <span class="doctrine-list__title">{principle.title}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section" id="claims-discipline">
    <div class="container narrow">
      <div class="review-posture" data-reveal>
        <p class="review-posture__label">{aboutPage.claimsDiscipline.label}</p>
        <h2 class="review-posture__title">{aboutPage.claimsDiscipline.title}</h2>
        <p class="review-posture__text">{aboutPage.claimsDiscipline.text}</p>
        <div class="review-posture__actions">
          <a class="button button--primary" href={aboutPage.finalCta.primaryAction.href}>{aboutPage.finalCta.primaryAction.label}</a>
          <a class="button button--secondary" href={aboutPage.finalCta.secondaryAction.href}>{aboutPage.finalCta.secondaryAction.label}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
