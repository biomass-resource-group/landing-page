---
import BaseLayout from '../layouts/BaseLayout.astro';
import CorridorDossier from '../components/CorridorDossier.astro';
import PageCta from '../components/PageCta.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import StatusBadge from '../components/StatusBadge.astro';
import {
  marketCorridors,
  marketsPage,
  pageMeta,
  pipelineMarkets,
  siteMeta,
  statusLegend,
} from '../data/site';

const meta = pageMeta.markets;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};

const corridorAnchor = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={marketsPage.hero.label}
    title={marketsPage.hero.title}
    intro={marketsPage.hero.intro}
    actions={[marketsPage.hero.primaryAction, marketsPage.hero.secondaryAction]}
    compact
  />

  <section class="section section--compact" id="corridor-status">
    <div class="container">
      <dl class="status-rail status-rail--legend" aria-label="Corridor status definitions">
        {
          statusLegend.map((status) => (
            <div class="status-rail__item" data-reveal>
              <dt>
                <StatusBadge status={status.key} label={status.label} />
              </dt>
              <dd>{status.description}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section class="section section--anchor" id="active-corridors">
    <div class="container">
      <SectionIntro
        label={marketsPage.activeIntro.label}
        title={marketsPage.activeIntro.title}
        intro={marketsPage.activeIntro.intro}
      />
      <div class="corridor-list">
        {
          marketCorridors.map((corridor) => (
            <div id={corridorAnchor(corridor.name)} class="corridor-anchor">
              <CorridorDossier {...corridor} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="pipeline">
    <div class="container">
      <SectionIntro
        label="Development regions"
        title="Development regions"
        intro="Earlier-stage regional work, kept distinct from active operating corridors."
      />
      <ul class="pipeline-strip" data-reveal>
        {
          pipelineMarkets.map((market) => (
            <li class={`pipeline-strip__item pipeline-strip__item--${market.status}`}>
              <span class="pipeline-strip__name">{market.name}</span>
              <span class="pipeline-strip__sep" aria-hidden="true">·</span>
              <span class="pipeline-strip__label">{market.statusLabel}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <PageCta
    label={marketsPage.finalCta.label}
    title={marketsPage.finalCta.title}
    intro={marketsPage.finalCta.intro}
    primaryAction={marketsPage.finalCta.primaryAction}
    secondaryAction={marketsPage.finalCta.secondaryAction}
  />
</BaseLayout>
