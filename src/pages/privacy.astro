---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { pageMeta, privacy, siteMeta } from '../data/site';

const meta = pageMeta.privacy;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={privacy.hero.label}
    title={privacy.hero.title}
    intro={privacy.hero.intro}
    actions={[
      { label: 'Contact BRG', href: '/contact/' },
      { label: 'Return home', href: '/', variant: 'secondary' },
    ]}
    compact
  />

  <section class="section" id="privacy-notice">
    <div class="container">
      <div class="privacy-stack" data-reveal>
        {
          privacy.sections.map((section, index) => (
            <article class="privacy-stack__item">
              <span class="privacy-stack__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <div class="privacy-stack__copy">
                <h2>{section.title}</h2>
                <p>{section.text}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
