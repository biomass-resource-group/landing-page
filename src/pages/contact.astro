---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import CopyEmailButton from '../components/CopyEmailButton.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { contact, pageMeta, siteMeta } from '../data/site';

const meta = pageMeta.contact;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};

const getCopyLabel = (label: string) => {
  switch (label) {
    case 'General':
      return 'Copy general email address';
    case 'Investors':
      return 'Copy investor email address';
    case 'Carbon buyers':
      return 'Copy carbon buyer email address';
    case 'Project partners':
      return 'Copy project partnerships email address';
    default:
      return `Copy ${label} email address`;
  }
};
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={contact.label}
    title={contact.hero.title}
    intro={contact.hero.intro}
    actions={[contact.hero.primaryAction, contact.hero.secondaryAction]}
    compact
  />

  <ContactForm />

  <section class="section section--tinted" id="direct-emails">
    <div class="container">
      <SectionIntro
        label="Direct emails"
        title="Direct emails"
        intro="Email addresses remain visible and selectable. Copy buttons add convenience when JavaScript is available."
      />
      <div class="email-grid">
        {
          contact.directEmails.map((email) => (
            <article class="email-card" data-reveal>
              <span>{email.label}</span>
              <!--email_off-->
              <a href={`mailto:${email.address}`}>{email.address}</a>
              <!--/email_off-->
              <CopyEmailButton address={email.address} label={getCopyLabel(email.label)} />
            </article>
          ))
        }
      </div>
      <p class="contact-reassurance">{contact.reassurance}</p>
    </div>
  </section>
</BaseLayout>
