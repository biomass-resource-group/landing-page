---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import ContactRouteCard from '../components/ContactRouteCard.astro';
import CopyEmailButton from '../components/CopyEmailButton.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { contact, pageMeta, siteMeta } from '../data/site';

const meta = pageMeta.contact;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: meta.title,
  url: `${siteMeta.siteUrl}${meta.path}`,
  description: meta.description,
};
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path} structuredData={structuredData}>
  <PageHero
    eyebrow={contact.label}
    title={contact.hero.title}
    intro={contact.hero.intro}
    actions={[contact.hero.primaryAction, contact.hero.secondaryAction]}
    meta={contact.hero.meta}
    compact
  >
    <div slot="visual" class="hero-panel hero-panel--routes">
      <div class="hero-panel__header">
        <p class="hero-panel__label">Routes</p>
        <h2 class="hero-panel__title">Select a route or use direct email.</h2>
      </div>
      <div class="hero-route-list">
        {contact.routes.map((route) => <a class="hero-route" href={`?type=${route.key}#inquiry-form`}><span>{route.label}</span><strong>{route.subject}</strong></a>)}
      </div>
    </div>
  </PageHero>

  <section class="section section--tinted" id="routes">
    <div class="container">
      <SectionIntro
        label="Contact route selector"
        title="Choose the team path before you write."
        intro="Selecting a route updates the inquiry form when JavaScript is available. Without JavaScript, each card still includes a direct email link."
      />
      <div class="card-grid card-grid--four">
        {
          contact.routes.map((route) => (
            <ContactRouteCard
              keyName={route.key}
              label={route.label}
              title={route.title}
              description={route.description}
              recipient={route.recipient}
              subject={route.subject}
            />
          ))
        }
      </div>
    </div>
  </section>

  <ContactForm />

  <section class="section section--tinted" id="direct-emails">
    <div class="container">
      <SectionIntro
        label="Direct emails"
        title="Email addresses remain visible and copyable."
        intro="Copy buttons are progressive enhancement. If JavaScript fails, the addresses are still plain, selectable text."
      />
      <div class="email-grid">
        {
          contact.directEmails.map((email) => (
            <article class="email-card" data-reveal>
              <span>{email.label}</span>
              <a href={`mailto:${email.address}`}>{email.address}</a>
              <CopyEmailButton address={email.address} />
            </article>
          ))
        }
      </div>
      <p class="contact-reassurance">{contact.reassurance}</p>
    </div>
  </section>
</BaseLayout>
