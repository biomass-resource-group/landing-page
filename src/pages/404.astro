---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { pageMeta } from '../data/site';

const meta = pageMeta.notFound;
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  noindex={meta.noindex}
  path={meta.path}
>
  <PageHero
    eyebrow="404"
    title="Page not found."
    intro="The route you opened does not exist or has moved. Continue through one of the core BRG paths below."
    actions={[
      { label: 'Go home', href: '/' },
      { label: 'Contact BRG', href: '/contact/', variant: 'secondary' },
    ]}
    compact
  >
    <div slot="visual" class="hero-panel hero-panel--routes">
      <div class="hero-panel__header">
        <p class="hero-panel__label">Recovery routes</p>
        <h2 class="hero-panel__title">Continue to a working page.</h2>
      </div>
      <div class="hero-route-list">
        <a class="hero-route" href="/platform/"><span>Platform</span><strong>Operating model</strong></a>
        <a class="hero-route" href="/markets/"><span>Markets</span><strong>Active corridors</strong></a>
        <a class="hero-route" href="/contact/"><span>Contact</span><strong>Direct inquiry</strong></a>
        <a class="hero-route" href="/"><span>Home</span><strong>Executive summary</strong></a>
      </div>
    </div>
  </PageHero>
</BaseLayout>
