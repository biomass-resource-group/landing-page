---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Page not found"
  description="The requested route could not be found. Return to the Biomass Resource Group homepage or continue to the platform, markets, or contact information."
  noindex={true}
  path="/404.html"
>
  <PageHero
    eyebrow="404"
    title="The page you requested does not exist."
    intro="Return to the main site to review the platform, active markets, and the right BRG contact path."
    actions={[
      { label: 'Back to homepage', href: '/' },
      { label: 'Contact BRG', href: '/contact/', variant: 'secondary' },
    ]}
    compact
  >
    <div slot="visual" class="hero-panel hero-panel--routes">
      <div class="hero-panel__header">
        <p class="hero-panel__label">Suggested routes</p>
        <h2 class="hero-panel__title">Continue from one of the core BRG routes.</h2>
      </div>
      <div class="hero-route-list">
        <a class="hero-route" href="/platform/">
          <span>Platform</span>
          <strong>Operating model</strong>
        </a>
        <a class="hero-route" href="/markets/">
          <span>Markets</span>
          <strong>Live corridors</strong>
        </a>
        <a class="hero-route" href="/contact/">
          <span>Contact</span>
          <strong>Talk with BRG</strong>
        </a>
      </div>
    </div>
  </PageHero>
</BaseLayout>
