---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageMeta } from '../data/site';

const destination = '/about/';
const meta = pageMeta.company;
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  path={meta.path}
  noindex={meta.noindex}
>
  <section class="section">
    <div class="container">
      <div class="contact-direct__panel">
        <div class="contact-direct__copy">
          <p class="page-cta__label">Page moved</p>
          <h1>About BRG now lives at /about/.</h1>
          <p>
            Existing links to /company/ are kept for compatibility, but the canonical BRG About page now uses the
            clearer /about/ path.
          </p>
        </div>
        <a class="button button--primary" href={destination}>Open About BRG</a>
      </div>
    </div>
  </section>

  <script src="/scripts/company-redirect.js" defer data-redirect-target={destination}></script>
</BaseLayout>
