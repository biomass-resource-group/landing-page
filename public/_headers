/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# /contact/ uses a Formspree form; the full route-specific CSP (including
# form-action 'self' https://formspree.io) is written by scripts/postbuild-dist.mjs.
# The directive below documents the intent; postbuild overwrites this block with
# the complete policy at build time.
/contact/
  Content-Security-Policy: form-action 'self' https://formspree.io
